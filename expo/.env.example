# Firebase Configuration — REQUIRED
# Create your own Firebase project at https://console.firebase.google.com,
# then copy these values from Project Settings → General → Your apps.
# The app will refuse to start if any of these are missing.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=

# Google Sign-In (Web Client ID from Firebase Console → Authentication → Sign-in method → Google)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# RevenueCat (in-app purchases)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# AI (Gemini) — NOT a client variable.
# The Gemini key lives only in Cloud Functions secrets and is never bundled
# into the app. Set it once with:
#     firebase functions:secrets:set GEMINI_API_KEY
