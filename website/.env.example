# Public Firebase web config (used by the admin login form)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side service account (paste the entire JSON on a single line, escaped)
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT=
# Same DATABASE_URL the mobile app uses (https://<project>-default-rtdb.firebaseio.com)
FIREBASE_DATABASE_URL=
# Random secret used to sign session cookies (≥ 32 chars)
ADMIN_SESSION_SECRET=
